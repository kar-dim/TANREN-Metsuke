<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TANREN_Metsuke.ViewModels"
             xmlns:models="clr-namespace:TANREN_Metsuke.Models"
             x:Class="TANREN_Metsuke.Views.RecordsView"
             x:DataType="vm:RecordsViewModel">

  <Grid RowDefinitions="Auto,*,Auto" Margin="20">

    <!-- Header -->
    <TextBlock x:Name="HeaderText" Grid.Row="0"
               FontSize="16" Foreground="{StaticResource TextDim}"
               HorizontalAlignment="Center" VerticalAlignment="Center"
               Margin="0,0,0,10"/>

    <!-- Human body viewbox -->
    <Viewbox x:Name="BodyViewbox" Grid.Row="1" Stretch="Uniform" StretchDirection="Both">
      <Grid Width="1000" Height="1000">
        <Image Source="/Assets/body.png" Stretch="Fill" IsHitTestVisible="False" />
        <Canvas x:Name="OverlayCanvas" Width="1000" Height="1000" />
      </Grid>
    </Viewbox>

    <!-- Detail panel, slides from right -->
    <Border x:Name="DetailPanel" Grid.Row="1"
            HorizontalAlignment="Right" Width="0"
            Background="{StaticResource SurfaceBg}" CornerRadius="8,0,0,8"
            ClipToBounds="True">
      <Grid RowDefinitions="Auto,*" Margin="20,16,20,16">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,14">
          <TextBlock x:Name="DetailTitle"
                     FontSize="17" FontWeight="Bold" TextWrapping="Wrap"
                     VerticalAlignment="Center"/>
          <Button x:Name="CloseDetailBtn" Grid.Column="1"
                  Content="✕" FontSize="15"
                  Background="Transparent" Foreground="{StaticResource TextFaint}"
                  BorderThickness="0" Padding="8,4"
                  VerticalAlignment="Top" Cursor="Hand"/>
        </Grid>

        <ScrollViewer Grid.Row="1">
          <ItemsControl x:Name="ExerciseRecordsList">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:ExercisePersonalRecord">
                <Border Margin="0,0,0,10"
                        Background="{StaticResource CardBg}"
                        BorderBrush="{StaticResource DividerBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="12,10">
                  <StackPanel Spacing="7">

                    <TextBlock Text="{Binding ExerciseName}"
                               FontWeight="SemiBold" FontSize="13"
                               FontFamily="{StaticResource OxaniumFont}"
                               Foreground="{StaticResource AccentBrush}"/>

                    <Grid ColumnDefinitions="80,*,Auto" ColumnSpacing="8">
                      <TextBlock Grid.Column="0" Text="Best weight"
                                 FontSize="11" Foreground="{StaticResource TextCaption}"
                                 VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="1" Text="{Binding BestWeightDisplay}"
                                 FontFamily="{StaticResource MonoFont}"
                                 FontSize="12" Foreground="{StaticResource TextPrimary}"/>
                      <TextBlock Grid.Column="2" Text="{Binding BestWeight.DateDisplay}"
                                 FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    </Grid>

                    <Grid ColumnDefinitions="80,*,Auto" ColumnSpacing="8">
                      <TextBlock Grid.Column="0" Text="Best set"
                                 FontSize="11" Foreground="{StaticResource TextCaption}"
                                 VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="1" Text="{Binding BestSetDisplay}"
                                 FontFamily="{StaticResource MonoFont}"
                                 FontSize="12" Foreground="{StaticResource TextPrimary}"/>
                      <TextBlock Grid.Column="2" Text="{Binding BestSet.DateDisplay}"
                                 FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    </Grid>

                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

      </Grid>
    </Border>

    <!-- Hover info bar -->
    <Border Grid.Row="2" Background="{StaticResource ItemBg}" CornerRadius="6"
            Padding="12,8" Margin="0,10,0,0"
            HorizontalAlignment="Center" MinWidth="400">
      <TextBlock x:Name="HoverInfo"
                 Text="Hover over a muscle group, click to see personal records"
                 FontSize="13" Foreground="{StaticResource TextSubtle}"
                 HorizontalAlignment="Center"/>
    </Border>

  </Grid>

</UserControl>
